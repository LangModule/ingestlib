# Jina AI Reranker — https://jina.ai/api-dashboard/
JINA_API_KEY=jina_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pinecone — https://app.pinecone.io/ → API Keys
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Qdrant — https://cloud.qdrant.io/ → API Keys, or a self-hosted server
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Postgres with the pgvector extension — RDS/Supabase/Neon, self-hosted,
# or docker run -p 5432:5432 pgvector/pgvector:pg18
PGVECTOR_URL=postgresql://postgres:password@localhost:5432/postgres

# MongoDB — Atlas connection string (any tier), or
# docker run -p 27017:27017 mongodb/mongodb-atlas-local
MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/

# Milvus — local standalone docker, or Zilliz Cloud (then set MILVUS_TOKEN)
MILVUS_URL=http://localhost:19530
MILVUS_TOKEN=

# SQLite needs no keys — set `vector_store: sqlite` in config.yaml and you're done.
