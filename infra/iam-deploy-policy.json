{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "IngestlibStack",
      "Effect": "Allow",
      "Action": "cloudformation:*",
      "Resource": "arn:aws:cloudformation:us-east-1:656077800096:stack/ingestlib-opensearch/*"
    },
    {
      "Sid": "IngestlibStackTemplateOps",
      "Effect": "Allow",
      "Action": [
        "cloudformation:ValidateTemplate",
        "cloudformation:GetTemplateSummary"
      ],
      "Resource": "*"
    },
    {
      "Sid": "IngestlibOpenSearchDomain",
      "Effect": "Allow",
      "Action": "es:*",
      "Resource": "arn:aws:es:us-east-1:656077800096:domain/ingestlib*"
    }
  ]
}
